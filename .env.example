# Supabase JWT secret — Project Settings → API → JWT Secret (bridges admin RLS)
SUPABASE_JWT_SECRET=

# Supabase data + storage (not used for login anymore)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
