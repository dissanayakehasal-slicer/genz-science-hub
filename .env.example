# Client bundle (Vercel: set these OR the SUPABASE_* names below — both work after redeploy)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Aliases also supported (Supabase dashboard "anon" key)
# VITE_SUPABASE_ANON_KEY=

# Server runtime (Vercel → Environment Variables)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: sync hasal admin via Auth API (run npm run bootstrap-admin locally)
# ADMIN_BOOTSTRAP_PASSWORD=Hasal@2011

# Optional: one-time remote bootstrap via bootstrapHasalAdmin server function
# ADMIN_SETUP_TOKEN=
