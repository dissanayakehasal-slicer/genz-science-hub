# Auth.js (Vercel)
AUTH_SECRET=
AUTH_URL=http://localhost:8080/api/auth

# Admin login (env fallback if DB not seeded yet)
ADMIN_USERNAME=hasal
ADMIN_PASSWORD=Hasal@2011

# One-time DB setup: POST /api/setup-db with Authorization: Bearer <SETUP_SECRET>
SETUP_SECRET=

# Vercel Postgres (Neon) — auto-injected when Storage is connected
POSTGRES_URL=

# Vercel Blob — auto-injected when Blob store is connected
BLOB_READ_WRITE_TOKEN=
